
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id      String @id @default(uuid())
  name    String
  address String
  age     Int
}

model Transaction {
  id      String @id @default(uuid())
  who     String
  company String
  value   Float
  date    DateTime
  type    String
}

enum TransactionType {  //Restrições para o tipo de transação
  income
  expense
  investment
}

model Goal {
  id      String @id @default(uuid())
  value   Float
  endDate DateTime
  type    TransactionType
  createdAt DateTime @default(now())
}